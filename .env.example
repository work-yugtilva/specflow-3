# Copy to .env.local for local dev — never commit .env.local

# Supabase (specflow-prod, us-east-1)
NEXT_PUBLIC_SUPABASE_URL=https://vphlxjlvwgomvydovxnb.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<sb_publishable_...>
SUPABASE_SERVICE_ROLE_KEY=<from Supabase dashboard → Settings → API>

# FastAPI / Railway
DATABASE_URL=<Supavisor pooler URL, port 6543>
DIRECT_URL=<direct DB URL, port 5432 — migrations only>

# LLM
ANTHROPIC_API_KEY=<sk-ant-...>
HELICONE_API_KEY=<sk-helicone-...>
OPENAI_API_KEY=<sk-...>

# Observability
SENTRY_DSN_FE=<from Sentry FE project>
SENTRY_DSN_BE=<from Sentry BE project>
NEXT_PUBLIC_POSTHOG_KEY=<phc_...>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Slack (alerts)
SLACK_WEBHOOK_ALERTS=<https://hooks.slack.com/...>
